  const t=state.traces.find(x=>x.id===currentTraceId);if(!t)return;
  CABLE_KEYS.forEach(k=>{
    t[k]=parseFloat(document.getElementById('tr_'+k).value)||0;
    t[k+'r']=parseFloat(document.getElementById('tr_'+k+'r').value)||0;
