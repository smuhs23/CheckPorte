// ---------- Trace Detail ----------
// Liste der Kabel-Typen für die Trasse
const CABLE_KEYS=['k1','k2','k3','k4','d','l','fb','re'];

function openTrace(id){
  const t=state.traces.find(x=>x.id===id);if(!t)return;
  currentTraceId=id;
  recalcSegments(t);
  // Migration: falls alte Struktur mit globaler reserve
  if(t.reserve!==undefined){
    const oldR=t.reserve;
    CABLE_KEYS.forEach(k=>{if(t[k+'r']===undefined)t[k+'r']=oldR;});
    delete t.reserve;
  }
  CABLE_KEYS.forEach(k=>{
    if(t[k]===undefined)t[k]=0;
    if(t[k+'r']===undefined)t[k+'r']=10;
  });

  const len=totalLen(t);
  document.getElementById('traceInfo').innerHTML=`<b>Gesamtlänge:</b> ${fmt(len)} m · ${t.points.length} Punkte · ${t.segments.length} Segmente`;
  document.getElementById('trNote').value=t.note||'';
  if(!t.photos)t.photos=[];
  renderPhotos('trPhotos',t.photos,updateTraceSum);
  renderTraceSegments(t);
  renderTracePoints(t);
  renderCables(t);
  updateTraceSum();
  openModal('modalTrace');
}

function renderCables(t){
  const c=document.getElementById('trCables');
  let html='<div class="cable-row"><div class="hd">Leitungstyp</div><div class="hd">Anzahl</div><div class="hd">Reserve %</div></div>';
  CABLE_KEYS.forEach(k=>{
    const price=CABLE_PRICES[k];
    html+=`<div class="cable-row">
      <div class="lbl">${CABLE_LABELS[k]}<small>${fmt(price)} €/m</small></div>
      <input type="number" min="0" id="tr_${k}" value="${t[k]||0}">
      <input type="number" min="0" max="200" step="1" id="tr_${k}r" value="${t[k+'r']||0}">
    </div>`;
  });
  c.innerHTML=html;
  CABLE_KEYS.forEach(k=>{
    document.getElementById('tr_'+k).oninput=updateTraceSum;
    document.getElementById('tr_'+k+'r').oninput=updateTraceSum;
  });
}
function renderTraceSegments(t){
  const c=document.getElementById('trSegList');
  c.innerHTML='';
  t.segments.forEach((seg,i)=>{
    const d=document.createElement('div');d.className='seg';
    d.innerHTML=`<div class="n">#${i+1}</div><div class="of" style="background:${TRACE_COLOR}">${seg.of}</div><div class="len">${fmt(seg.len)} m</div>${seg.hand?'<div class="hand">HAND</div>':''}<div style="color:#999;font-size:16px">›</div>`;
    d.onclick=()=>openSeg(t.id,i);
    c.appendChild(d);
  });
}
function renderTracePoints(t){
  const c=document.getElementById('trPoints');
  c.innerHTML='';
  t.points.forEach((p,i)=>{
    const d=document.createElement('div');d.className='pt';
    d.innerHTML=`<div class="n">${i+1}</div><div class="coords">${p[0].toFixed(6)}, ${p[1].toFixed(6)}</div>`;
    const btn=document.createElement('button');btn.className='del';btn.textContent='🗑';
    btn.onclick=()=>{
      if(t.points.length<=2){alert('Mindestens 2 Punkte erforderlich');return;}
      if(!confirm(`Punkt #${i+1} löschen?`))return;
      t.points.splice(i,1);
      if(i===0)t.segments.splice(0,1);
      else if(i>=t.points.length)t.segments.splice(i-1,1);
      else t.segments.splice(i-1,1);
      recalcSegments(t);
      document.getElementById('traceInfo').innerHTML=`<b>Gesamtlänge:</b> ${fmt(totalLen(t))} m · ${t.points.length} Punkte · ${t.segments.length} Segmente`;
      renderTracePoints(t);
      renderTraceSegments(t);
      updateTraceSum();
      render();
    };
    d.appendChild(btn);
    c.appendChild(d);
  });
}
function updateTraceSum(){
  const t=state.traces.find(x=>x.id===currentTraceId);if(!t)return;
  const len=totalLen(t);
  let sumTiefbau=0;
  t.segments.forEach(seg=>{
    const def=OF_DEFS[seg.of];if(!def)return;
    sumTiefbau+=seg.len*(def.prOF+def.prWH+(seg.hand?PRICE_HAND:PRICE_GRABEN));
  });
  let sumCable=0;
  const details=[];
  CABLE_KEYS.forEach(k=>{
    const n=parseFloat(document.getElementById('tr_'+k).value)||0;
    const r=parseFloat(document.getElementById('tr_'+k+'r').value)||0;
    if(n>0){
      const effLen=len*(1+r/100);
      const cost=effLen*n*CABLE_PRICES[k];
      sumCable+=cost;
      details.push(`${k}: ${n}×${fmt(effLen)}m`);
    }
  });
  const total=sumTiefbau+sumCable;
  document.getElementById('trSum').innerHTML=`Tiefbau: ${fmtEur(sumTiefbau)} · Kabel: ${fmtEur(sumCable)}<br><span style="font-size:16px">Σ Trasse: ${fmtEur(total)}</span>`;
}

