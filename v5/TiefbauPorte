let finishBtn=null;
function showFinishBtn(show){
  if(show&&!finishBtn){finishBtn=document.createElement('button');finishBtn.className='fab';finishBtn.textContent='✓ Trasse fertig';finishBtn.onclick=finishTrace;document.getElementById('map').appendChild(finishBtn);}
