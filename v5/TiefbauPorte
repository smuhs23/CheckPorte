  fb:30.00,  // Flachband V4A Erdung (Default)
  re:40.20,  // Runderder V4A Erdung (aLV)
  te:663.30  // Tiefenerder V4A (aLV, je Stück - aber in Kabel-Liste je Meter 0)
};
const CABLE_LABELS = {
  k1:'Stromkabel ≤22kW',
  k2:'Stromkabel >22 ≤50kW',
  k3:'Stromkabel >50 <100kW',
  k4:'Stromkabel ≥100 ≤150kW',
  d:'Datenkabel',
  l:'Leerrohr',
  fb:'Flachband V4A (Erdung)',
  re:'Runderder V4A (Erdung)'
};
const PRICE_GRABEN = 159.50; // 17.
const PRICE_HAND   = 89.10;  // 15.
const TRACE_COLOR  = '#D32F2F'; // Kabelgraben = rot

// ---------- State ----------
let state = {
  meta:{we:'',loc:'',date:new Date().toISOString().slice(0,10),author:'',note:'',gk:0,wg:0,konta:false,denk:false,kontaPct:20,denkPct:15},
  catalog:JSON.parse(JSON.stringify(DEFAULT_CATALOG)),
  objects:[],traces:[],selectedCat:null,
  viz:{hw:true,tr:true}
};
let mode='pin', currentTrace=null, currentObjId=null, currentTraceId=null, currentEditCatId=null, currentSegIdx=null;

function save(){try{localStorage.setItem('tbp_v5',JSON.stringify(state));}catch(e){console.warn(e);}}
function load(){
  try{
    // Versuche v5 zuerst, dann v4 als Migration
    let s=localStorage.getItem('tbp_v5')||localStorage.getItem('tbp_v4');
    if(!s) return;
    const l=JSON.parse(s);
    state.meta=Object.assign(state.meta,l.meta||{});
    if(l.catalog)state.catalog=l.catalog;
    if(l.objects)state.objects=l.objects;
    if(l.traces){
      state.traces=l.traces;
      // Migration alter OF-Keys: OF2B → OF2, altes OF1 (unbefestigt) → OF0, OF2 (Pflaster) → OF1
      state.traces.forEach(t=>{
        if(t.segments){
          t.segments.forEach(seg=>{
            if(seg.of==='OF2B') seg.of='OF2';
            // Die OF-Bedeutung hat sich geändert, aber eine automatische
            // Umbenennung wäre falsch - alte OF1/OF2/OF3 bleiben numerisch gleich
            if(!OF_DEFS[seg.of]) seg.of='OF0';
          });
        }
      });
    }
    if(l.viz)state.viz=Object.assign(state.viz,l.viz);
  }catch(e){console.warn(e);}
}
load();

// ---------- Map ----------
const map = L.map('map',{zoomControl:false,tap:true}).setView([52.4512,13.2890],18);
L.control.zoom({position:'bottomright'}).addTo(map);

const layerOSM = L.tileLayer('https://{s}.tile.openstreetmap.de/{z}/{x}/{y}.png',{attribution:'© OpenStreetMap',maxZoom:19,subdomains:'abc',crossOrigin:true});
const layerSat = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',{attribution:'© Esri',maxZoom:20,crossOrigin:true});
layerOSM.addTo(map);
let activeLayer='map';

document.getElementById('lyrMap').onclick=()=>{if(activeLayer==='map')return;map.removeLayer(layerSat);layerOSM.addTo(map);document.getElementById('lyrMap').classList.add('active');document.getElementById('lyrSat').classList.remove('active');activeLayer='map';};
document.getElementById('lyrSat').onclick=()=>{if(activeLayer==='sat')return;map.removeLayer(layerOSM);layerSat.addTo(map);document.getElementById('lyrSat').classList.add('active');document.getElementById('lyrMap').classList.remove('active');activeLayer='sat';};
