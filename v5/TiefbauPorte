// ---------- CANVAS OVERLAY FÜR TRASSEN ----------
// html2canvas rendert Leaflet SVG-Polylines nicht zuverlässig.
// Wir zeichnen die Trassen manuell als Canvas-Linien — pro Segment in OF-Farbe.
// Scale = canvas.width / map.getSize().x (nicht offsetWidth, weil das mit Borders etc abweicht)
function drawTracesOnCanvas(canvas){
  if(state.traces.length===0) return;
  const size=map.getSize(); // Leaflet-interne Größe (Point {x,y})
  const sx=canvas.width/size.x, sy=canvas.height/size.y;
  const ctx=canvas.getContext('2d');

  ctx.save();
  ctx.lineWidth=9*sx;
  ctx.lineCap='round';
  ctx.lineJoin='round';
  ctx.shadowColor='rgba(0,0,0,0.5)';
  ctx.shadowBlur=4*sx;
  ctx.shadowOffsetX=0;
  ctx.shadowOffsetY=1*sx;

  state.traces.forEach(t=>{
    for(let i=0;i<t.segments.length;i++){
      const seg=t.segments[i];
      const col=OF_DEFS[seg.of]?.color||TRACE_COLOR;
      // latLngToContainerPoint gibt Pixel relativ zum map-container, was html2canvas captured
      const a=map.latLngToContainerPoint(L.latLng(t.points[i][0],t.points[i][1]));
      const b=map.latLngToContainerPoint(L.latLng(t.points[i+1][0],t.points[i+1][1]));
      ctx.strokeStyle=col;
      ctx.beginPath();
      ctx.moveTo(a.x*sx, a.y*sy);
      ctx.lineTo(b.x*sx, b.y*sy);
      ctx.stroke();
    }
  });

  // Vertex-Punkte ohne Schatten
  ctx.shadowColor='transparent';
  ctx.shadowBlur=0;
  state.traces.forEach(t=>{
    t.points.forEach((pt,i)=>{
      const col=i<t.segments.length?OF_DEFS[t.segments[i].of]?.color||TRACE_COLOR:(i>0?OF_DEFS[t.segments[i-1].of]?.color||TRACE_COLOR:TRACE_COLOR);
      const p=map.latLngToContainerPoint(L.latLng(pt[0],pt[1]));
      ctx.beginPath();
      ctx.fillStyle='#fff';
      ctx.arc(p.x*sx, p.y*sy, 6*sx, 0, Math.PI*2);
      ctx.fill();
      ctx.fillStyle=col;
      ctx.beginPath();
      ctx.arc(p.x*sx, p.y*sy, 4*sx, 0, Math.PI*2);
      ctx.fill();
      // Punkt-Nummer
      ctx.fillStyle=col;
      ctx.font=`bold ${9*sx}px Arial`;
      ctx.textAlign='center';
      ctx.textBaseline='middle';
      ctx.fillText(String(i+1), p.x*sx, p.y*sy-11*sx);
    });
  });
  ctx.restore();
}

// ---------- CAPTURE MAP ----------
// Wenn keepView=true, wird der aktuelle Kartenausschnitt behalten (kein Auto-Fit)
async function captureMap(keepView){
  const wasHw=state.viz.hw, wasTr=state.viz.tr;
  state.viz.hw=true; state.viz.tr=true;
  render();
  if(!keepView){
    const pts=[];
    state.objects.forEach(o=>pts.push([o.lat,o.lng]));
    state.traces.forEach(t=>t.points.forEach(p=>pts.push(p)));
    if(pts.length>0){
      try{map.fitBounds(pts,{padding:[60,60],maxZoom:19,animate:false});}catch(e){}
    }
  }
  map.invalidateSize();
  await new Promise(r=>setTimeout(r,1500));

  // Leaflet-Container statt #map div — das ist die echte Leaflet-Zeichenfläche
  const mapContainer=map.getContainer();
  const size=map.getSize();

  // Overlay-Elemente verstecken
  const hide=document.querySelectorAll('.searchbar, .searchres, .layerctl, .legend, .info, .fab, .sel-badge, .leaflet-control-zoom, .leaflet-control-attribution');
  hide.forEach(el=>el.style.visibility='hidden');
  // SVG-Polylines im Overlay-Pane verstecken (wir zeichnen sie selbst auf Canvas)
  const overlayPane=mapContainer.querySelector('.leaflet-overlay-pane');
  const oldVis=overlayPane?overlayPane.style.visibility:'';
  if(overlayPane) overlayPane.style.visibility='hidden';

  try{
    const canvas=await html2canvas(mapContainer,{
      useCORS:true,
      allowTaint:true,
      backgroundColor:'#fff',
      logging:false,
      scale:1.5,
      width:size.x,
      height:size.y,
      windowWidth:size.x,
      windowHeight:size.y,
      x:0,
      y:0
    });
    // Trassen mit korrekten Koordinaten drauf zeichnen
    drawTracesOnCanvas(canvas);
    hide.forEach(el=>el.style.visibility='');
    if(overlayPane) overlayPane.style.visibility=oldVis;
    state.viz.hw=wasHw; state.viz.tr=wasTr; render();
    return {dataUrl:canvas.toDataURL('image/jpeg',0.9),width:canvas.width,height:canvas.height};
  }catch(e){
    hide.forEach(el=>el.style.visibility='');
    if(overlayPane) overlayPane.style.visibility=oldVis;
    state.viz.hw=wasHw; state.viz.tr=wasTr; render();
    console.warn('Map capture failed:',e);
    return null;
  }
}

// ---------- PDF ----------
async function doExportPDF(){
  const {jsPDF}=window.jspdf;
  const doc=new jsPDF({orientation:'landscape',unit:'mm',format:'a4'});
  const t=calcTotals();
  const NAVY=[27,45,94],GREEN=[120,181,26],DARK=[26,26,26];
  const W=297, H=210;
  const ML=14, MR=14;
  const CW=W-ML-MR;

  function drawHeader(title){
    doc.setFillColor(...NAVY);doc.rect(0,0,W,18,'F');
    doc.setFillColor(...GREEN);doc.rect(0,18,W,1.5,'F');
    doc.setTextColor(255,255,255);doc.setFont('helvetica','bold');doc.setFontSize(13);
    doc.text('TiefbauPorte · Vor-Ort-Check',ML,11);
    doc.setFontSize(9);doc.setFont('helvetica','normal');
    doc.text('Union E GmbH · Die HPM Mobilmacher',ML,16);
    if(title){
      doc.setFont('helvetica','bold');doc.setFontSize(11);
      doc.text(title,W-MR,11,{align:'right'});
    }
  }
  function drawFooter(){
    doc.setTextColor(...NAVY);doc.setFont('helvetica','normal');doc.setFontSize(7);
    doc.text('Union E GmbH · Vinckeweg 15 · 47119 Duisburg · Tel. 0203/996 26 0 · info@union-e.de',ML,H-6);
  }

  // ===== SEITE 1: Deckblatt =====
  drawHeader('Deckblatt');
  doc.setTextColor(...DARK);
  let y=26;
  const leftX=ML, rightX=W/2+5, colW=(W-ML-MR-10)/2;

  doc.setFillColor(...GREEN);doc.rect(leftX,y,colW,6,'F');
  doc.setTextColor(...NAVY);doc.setFont('helvetica','bold');doc.setFontSize(12);
  doc.text('Projektdaten',leftX+2,y+4.3);
  y+=10;
  doc.setTextColor(...DARK);doc.setFont('helvetica','normal');doc.setFontSize(10);
  const lines=[['WE-Nummer:',state.meta.we||'-'],['Liegenschaft:',state.meta.loc||'-'],['Datum:',state.meta.date||'-'],['Ersteller:',state.meta.author||'-']];
  if(state.meta.konta||state.meta.denk){
    const f=[];
    if(state.meta.konta)f.push(`Konta +${state.meta.kontaPct}%`);
    if(state.meta.denk)f.push(`Denkmal +${state.meta.denkPct}%`);
    lines.push(['Standort:',f.join(' · ')]);
  }
  lines.forEach(([k,v])=>{
    doc.setFont('helvetica','bold');doc.text(k,leftX,y);
    doc.setFont('helvetica','normal');doc.text(String(v),leftX+32,y);y+=5;
  });
  if(state.meta.note){
    y+=1;doc.setFont('helvetica','bold');doc.text('Bemerkung:',leftX,y);y+=5;
    doc.setFont('helvetica','normal');
    const nl=doc.splitTextToSize(state.meta.note,colW-4);
    doc.text(nl,leftX,y);y+=nl.length*4.5;
  }

  // Rechte Spalte Gesamt-Box
  let ry=26+10;
  doc.setFillColor(...NAVY);doc.rect(rightX,26,colW,H-40,'F');
  doc.setFillColor(...GREEN);doc.rect(rightX,26,colW,6,'F');
  doc.setTextColor(...NAVY);doc.setFont('helvetica','bold');doc.setFontSize(12);
  doc.text('Kalkulation Gesamt',rightX+2,30.3);
  doc.setTextColor(255,255,255);doc.setFontSize(10);
  ry+=4;
  const kl=[['Σ Hardware',fmtEur(t.sumObj)],['Σ Tiefbau',fmtEur(t.sumTrace)]];
  if(t.surchargeKonta>0)kl.push(['+ Kontamination '+state.meta.kontaPct+'%',fmtEur(t.surchargeKonta)]);
  if(t.surchargeDenk>0) kl.push(['+ Denkmalschutz '+state.meta.denkPct+'%',fmtEur(t.surchargeDenk)]);
  kl.push(['Netto',fmtEur(t.netto)]);
  if(state.meta.gk>0)kl.push(['+ GK '+state.meta.gk+'%',fmtEur(t.gk)]);
  if(state.meta.wg>0)kl.push(['+ W+G '+state.meta.wg+'%',fmtEur(t.wg)]);
  kl.forEach(([k,v])=>{doc.setFont('helvetica','normal');doc.text(k,rightX+3,ry);doc.setFont('helvetica','bold');doc.text(v,rightX+colW-3,ry,{align:'right'});ry+=6;});
  ry+=3;
  doc.setFillColor(...GREEN);doc.rect(rightX+2,ry-4,colW-4,10,'F');
  doc.setTextColor(...NAVY);doc.setFont('helvetica','bold');doc.setFontSize(14);
  doc.text('GESAMT',rightX+4,ry+2.5);
  doc.text(fmtEur(t.total),rightX+colW-4,ry+2.5,{align:'right'});

  doc.setTextColor(...DARK);doc.setFont('helvetica','normal');doc.setFontSize(9);
  let statY=H-30;
  doc.setFont('helvetica','bold');doc.text('Erfassung:',leftX,statY);statY+=5;
  doc.setFont('helvetica','normal');
  const totalM=state.traces.reduce((s,tr)=>s+totalLen(tr),0);
  doc.text(`${state.objects.length} Hardware · ${state.traces.length} Trassen · ${totalM.toFixed(1)} m`,leftX,statY);
  drawFooter();

  // ===== SEITE 2: Karte =====
  showInfo('PDF: Karte wird aufgenommen...');
  const keepView=document.getElementById('expKeepView')?.checked||false;
  const cap=await captureMap(keepView);
  doc.addPage();
  drawHeader('Karten-Auszug');
  if(cap){
    const maxW=CW, maxH=H-30;
    const srcA=cap.width/cap.height, boxA=maxW/maxH;
    let imgW,imgH;
    if(srcA>boxA){imgW=maxW;imgH=maxW/srcA;}
    else {imgH=maxH;imgW=maxH*srcA;}
    const imgX=ML+(maxW-imgW)/2, imgY=24+(maxH-imgH)/2;
    try{
      doc.addImage(cap.dataUrl,'JPEG',imgX,imgY,imgW,imgH);
      doc.setDrawColor(...NAVY);doc.setLineWidth(0.3);doc.rect(imgX,imgY,imgW,imgH);
      doc.setTextColor(...NAVY);doc.setFontSize(8);doc.setFont('helvetica','italic');
      doc.text(`${state.meta.loc||'Liegenschaft'} · ${state.objects.length} Objekte · ${state.traces.length} Trassen`,W/2,H-8,{align:'center'});
    }catch(e){doc.text('Karten-Screenshot fehlgeschlagen',W/2,H/2,{align:'center'});}
  } else {
    doc.setTextColor(...DARK);doc.setFontSize(11);
    doc.text('Karte konnte nicht aufgenommen werden',W/2,H/2,{align:'center'});
  }
  drawFooter();

  // ===== Hardware Details =====
  if(state.objects.length>0){
    doc.addPage();
    drawHeader('Asset-Aufschlüsselung · Hardware');
    const order=['Ladeinfrastruktur','Verteilung','Netzanschluss','Ausstattung','Erdung','Durchbruch','Sonstiges'];
    const byCat={};
    state.objects.forEach((o,idx)=>{
      const c=state.catalog.find(x=>x.id===o.catId)||{};
      (byCat[c.category||'Sonstiges']=byCat[c.category||'Sonstiges']||[]).push({o,c,idx:idx+1});
    });
    let ay=25;
    order.filter(k=>byCat[k]).forEach(cat=>{
      if(ay>H-30){doc.addPage();drawHeader('Hardware (Forts.)');ay=25;}
      doc.setFillColor(...GREEN);doc.rect(ML,ay,CW,6,'F');
      doc.setTextColor(...NAVY);doc.setFont('helvetica','bold');doc.setFontSize(10);
      doc.text(cat,ML+2,ay+4.2);
      ay+=8;
      const rows=byCat[cat].map(it=>{
        const suf=[it.o.amps?it.o.amps+'A':'',it.o.kw?it.o.kw+'kW':''].filter(Boolean).join(' · ');
        return ['#'+it.idx,it.c.icon||'',(it.c.name||'')+(suf?' · '+suf:''),it.c.pos||'',it.o.qty+' '+(it.c.unit||''),fmt(it.o.price),fmt(it.o.qty*it.o.price),`${it.o.lat.toFixed(6)}, ${it.o.lng.toFixed(6)}`,it.o.note||'',(it.o.photos&&it.o.photos.length)?`📷${it.o.photos.length}`:''];
      });
      doc.autoTable({
        startY:ay,
        head:[['#','Typ','Bezeichnung','LV','Menge','EP (€)','Summe (€)','GPS','Notiz','Fotos']],
        body:rows,theme:'grid',
        headStyles:{fillColor:NAVY,textColor:255,fontStyle:'bold',fontSize:8},
        bodyStyles:{fontSize:8,cellPadding:2},
        alternateRowStyles:{fillColor:[245,245,245]},
        columnStyles:{0:{cellWidth:11,halign:'center'},1:{cellWidth:14,fontStyle:'bold',halign:'center'},2:{cellWidth:62},3:{cellWidth:14,halign:'center'},4:{cellWidth:17,halign:'right'},5:{cellWidth:22,halign:'right'},6:{cellWidth:24,halign:'right',fontStyle:'bold'},7:{cellWidth:36,fontSize:7},8:{cellWidth:46,fontSize:7},9:{cellWidth:13,halign:'center'}},
        margin:{left:ML,right:MR}
      });
      ay=doc.lastAutoTable.finalY+5;
    });
    drawFooter();
  }

  // ===== Trassen Details =====
  if(state.traces.length>0){
    doc.addPage();
    drawHeader('Asset-Aufschlüsselung · Trassen');
    const rows=[];
    state.traces.forEach((tr,i)=>{
      const tl=totalLen(tr);
      const ofBreak={};
      tr.segments.forEach(s=>{ofBreak[s.of]=(ofBreak[s.of]||0)+s.len;});
      const ofText=Object.entries(ofBreak).map(([k,v])=>`${k}: ${fmt(v)}m`).join('\n');

      // Kabel-Details
      const cables=[];
      let cableSum=0;
      CABLE_KEYS.forEach(k=>{
        const n=Number(tr[k])||0;
        if(n<=0) return;
        const r=Number(tr[k+'r'])||0;
        const effLen=tl*(1+r/100);
        const cost=effLen*n*CABLE_PRICES[k];
        cableSum+=cost;
        cables.push(`${n}× ${CABLE_LABELS[k]} (+${r}%)`);
      });

      // Tiefbau-Summe
      let tbSum=0;
      tr.segments.forEach(s=>{const d=OF_DEFS[s.of];if(d)tbSum+=s.len*(d.prOF+d.prWH+(s.hand?PRICE_HAND:PRICE_GRABEN));});
      const total=tbSum+cableSum;
      const start=tr.points[0],end=tr.points[tr.points.length-1];
      rows.push(['#'+(i+1),fmt(tl)+' m',ofText,cables.join('\n')||'-',fmt(total),`${start[0].toFixed(5)},${start[1].toFixed(5)} →\n${end[0].toFixed(5)},${end[1].toFixed(5)}`,tr.note||'']);
    });
    doc.autoTable({
      startY:25,
      head:[['#','Länge','OF-Aufteilung','Kabel-Belegung','Summe (€)','GPS Start → Ende','Notiz']],
      body:rows,theme:'grid',
      headStyles:{fillColor:NAVY,textColor:255,fontStyle:'bold',fontSize:8},
      bodyStyles:{fontSize:8,cellPadding:2,valign:'top'},
      alternateRowStyles:{fillColor:[245,245,245]},
      columnStyles:{0:{cellWidth:12,halign:'center'},1:{cellWidth:22,halign:'right',fontStyle:'bold'},2:{cellWidth:32,fontSize:7},3:{cellWidth:62,fontSize:7},4:{cellWidth:26,halign:'right',fontStyle:'bold'},5:{cellWidth:48,fontSize:6},6:{cellWidth:55,fontSize:7}},
      margin:{left:ML,right:MR}
    });
    drawFooter();
  }

  // ===== Fotos =====
  const allPhotos=[];
  state.objects.forEach((o,idx)=>{const c=state.catalog.find(x=>x.id===o.catId);(o.photos||[]).forEach(p=>allPhotos.push({label:`#${idx+1} ${c?.name||''}${o.note?' · '+o.note:''}`.substring(0,60),data:p}));});
  state.traces.forEach((tr,i)=>{(tr.photos||[]).forEach(p=>allPhotos.push({label:`Trasse #${i+1}${tr.note?' · '+tr.note:''}`.substring(0,60),data:p}));});
  if(allPhotos.length>0){
    doc.addPage();drawHeader('Fotodokumentation');
    const photoW=85,photoH=64,gap=8,startX=ML+5,startY=26,cols=3;
    let px=startX,py=startY,col=0;
    allPhotos.forEach(p=>{
      if(py+photoH+10>H-10){doc.addPage();drawHeader('Fotodokumentation (Forts.)');px=startX;py=startY;col=0;}
      try{doc.addImage(p.data,'JPEG',px,py,photoW,photoH);doc.setDrawColor(...NAVY);doc.setLineWidth(0.2);doc.rect(px,py,photoW,photoH);doc.setTextColor(...NAVY);doc.setFontSize(7);doc.setFont('helvetica','normal');doc.text(p.label,px,py+photoH+4,{maxWidth:photoW});}catch(e){}
      col++;
      if(col>=cols){col=0;px=startX;py+=photoH+gap+6;}
      else {px+=photoW+gap;}
    });
    drawFooter();
  }

  // Seitenzahlen
  const pc=doc.internal.getNumberOfPages();
  for(let i=1;i<=pc;i++){
    doc.setPage(i);
    doc.setTextColor(...NAVY);doc.setFontSize(7);doc.setFont('helvetica','normal');
    doc.text(`Seite ${i}/${pc}`,W-MR,H-6,{align:'right'});
  }
  doc.save(`UnionE_VorOrtCheck_${state.meta.we||'WE'}_${state.meta.date}.pdf`);
  showInfo('PDF fertig ✓');
}

// ---------- JSON ----------
function doExportJSON(){
  const blob=new Blob([JSON.stringify(state,null,2)],{type:'application/json'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');
  a.href=url;a.download=`TiefbauPorte_${state.meta.we||'WE'}_${state.meta.date}.json`;
  a.click();
}
function doImportJSON(e){
  const f=e.target.files[0];if(!f)return;
  const r=new FileReader();
  r.onload=ev=>{try{state=JSON.parse(ev.target.result);render();closeModal('modalExport');showInfo('Import OK');}catch(err){alert('Import-Fehler: '+err.message);}};
  r.readAsText(f);
}
function resetAll(){
  if(!confirm('ALLE Aufnahmen löschen? (Katalog & Projekt bleiben)'))return;
  state.objects=[];state.traces=[];
  closeModal('modalExport');render();
}
function resetTraces(){
  if(state.traces.length===0){showInfo('Keine Trassen vorhanden');return;}
  if(!confirm(`Wirklich alle ${state.traces.length} Trassen löschen?`))return;
  state.traces=[];
  closeModal('modalExport');render();
  showInfo('Alle Trassen gelöscht');
}

