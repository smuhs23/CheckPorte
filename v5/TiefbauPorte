// ---------- Map Click ----------
map.on('click',e=>{
  if(mode==='pin'){
    if(!state.selectedCat){openCatalog();return;}
    const cat=state.catalog.find(c=>c.id===state.selectedCat);if(!cat)return;
    const o={id:uid(),catId:cat.id,lat:e.latlng.lat,lng:e.latlng.lng,qty:1,price:cat.price,amps:'',kw:'',note:'',photos:[]};
    state.objects.push(o);render();
  } else if(mode==='trace'){
    if(!currentTrace)currentTrace={points:[],line:null};
    currentTrace.points.push([e.latlng.lat,e.latlng.lng]);
    if(currentTrace.line)drawLayer.removeLayer(currentTrace.line);
    currentTrace.line=L.polyline(currentTrace.points,{color:TRACE_COLOR,weight:8,dashArray:'10,6',opacity:.9}).addTo(drawLayer);
    L.circleMarker([e.latlng.lat,e.latlng.lng],{radius:6,color:'#fff',fillColor:TRACE_COLOR,fillOpacity:1,weight:2}).addTo(drawLayer);
    let len=0;for(let i=1;i<currentTrace.points.length;i++)len+=distMeters(currentTrace.points[i-1],currentTrace.points[i]);
    showInfo(`Trasse · ${currentTrace.points.length} Pkt · ${fmt(len)} m`);
  }
});
map.on('dblclick',()=>{if(mode==='trace'&&currentTrace&&currentTrace.points.length>=2)finishTrace();});
map.doubleClickZoom.disable();

function cancelDrawTrace(){drawLayer.clearLayers();currentTrace=null;}

function finishTrace(){
  if(!currentTrace||currentTrace.points.length<2){showInfo('Mindestens 2 Punkte','err');return;}
  const segments=[];
  for(let i=0;i<currentTrace.points.length-1;i++){
    segments.push({of:'OF0',hand:false,len:distMeters(currentTrace.points[i],currentTrace.points[i+1])});
  }
  // Default Kabel-Belegung (alles auf 0, User vergibt nach Bedarf)
  const t={id:uid(),points:currentTrace.points,segments,
    k1:0,k1r:10,k2:0,k2r:10,k3:0,k3r:10,k4:0,k4r:10,
    d:0,dr:10,l:0,lr:10,fb:0,fbr:10,re:0,rer:10,
    note:'',photos:[]};
  state.traces.push(t);cancelDrawTrace();render();openTrace(t.id);
}

