<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#1B2D5E">
<title>TiefbauPorte · Vor-Ort-Check</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<style>
:root{
  --navy:#1B2D5E;--navy-dark:#0F1B3D;--green:#78B51A;--green-dark:#5A8A12;
  --text:#1A1A1A;--bg:#F4F4F4;--bg2:#EAEAEA;--white:#FFFFFF;
  --of1:#8BC34A;--of2:#B0A090;--of3:#2C2C2C;
  --red:#D32F2F;--orange:#F57C00;--amber:#FFA000;
}
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{margin:0;padding:0;height:100%;font-family:Calibri,Arial,sans-serif;color:var(--text);background:var(--bg);overscroll-behavior:none}
body{display:flex;flex-direction:column;height:100vh;height:100dvh}

header.topbar{background:var(--navy);color:#fff;padding:10px 14px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 2px 6px rgba(0,0,0,.25);z-index:1000;gap:10px}
header.topbar .brand{display:flex;align-items:center;gap:10px;min-width:0}
header.topbar .logo{width:32px;height:32px;background:var(--green);color:var(--navy);font-weight:bold;display:flex;align-items:center;justify-content:center;border-radius:6px;font-size:20px;flex-shrink:0}
header.topbar h1{font-size:15px;margin:0;font-weight:700;line-height:1.1;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
header.topbar h1 small{display:block;font-size:11px;opacity:.8;font-weight:400}
header.topbar .sum{background:var(--green);color:var(--navy);padding:8px 14px;border-radius:8px;font-weight:bold;font-size:14px;white-space:nowrap;box-shadow:0 2px 4px rgba(0,0,0,.2)}

#map{flex:1;width:100%;z-index:1;position:relative;background:#e8e8e8}

.modebar{background:var(--white);border-top:2px solid var(--navy);padding:8px;display:flex;gap:6px;overflow-x:auto;z-index:500;justify-content:center}
.modebar button{flex:1 1 auto;min-width:90px;max-width:180px;background:var(--bg);border:2px solid #ccc;border-radius:8px;padding:10px 8px;font-size:12px;font-weight:700;color:var(--navy);white-space:nowrap;cursor:pointer;font-family:inherit;transition:all .15s}
.modebar button:hover{background:#e8e8e8}
.modebar button.active{background:var(--navy);color:#fff;border-color:var(--navy);box-shadow:0 2px 6px rgba(27,45,94,.3)}
.modebar button.trace.active{background:var(--green);color:var(--navy);border-color:var(--green-dark)}
.modebar button.edit.active{background:var(--orange);color:#fff;border-color:var(--orange)}

.toolbar{background:var(--navy);padding:10px;display:grid;grid-template-columns:repeat(4,1fr);gap:8px;z-index:500}
.toolbar button{background:var(--green);color:var(--navy);border:none;border-radius:8px;padding:12px 6px;font-size:12px;font-weight:bold;cursor:pointer;font-family:inherit;line-height:1.2;box-shadow:0 2px 4px rgba(0,0,0,.2)}
.toolbar button.sec{background:#fff;color:var(--navy)}

/* ========== SEARCH BAR (oben in der Karte) ========== */
.searchbar{position:absolute;top:10px;left:10px;right:130px;background:rgba(255,255,255,.97);padding:6px 8px;border-radius:8px;z-index:800;box-shadow:0 3px 8px rgba(0,0,0,.25);display:flex;gap:4px;max-width:450px;pointer-events:auto}
.searchbar input{flex:1;padding:8px;border:1px solid #ccc;border-radius:6px;font-size:13px;background:#fff}
.searchbar button{background:var(--navy);color:#fff;border:none;border-radius:6px;padding:0 12px;font-weight:bold;cursor:pointer;font-family:inherit;font-size:13px}
.searchbar button.snap{background:var(--green);color:var(--navy)}
.searchres{position:absolute;top:56px;left:10px;background:#fff;border-radius:8px;box-shadow:0 4px 12px rgba(0,0,0,.3);z-index:900;max-width:450px;max-height:260px;overflow-y:auto;display:none;pointer-events:auto}
.searchres.show{display:block}
.searchres .item{padding:10px 12px;border-bottom:1px solid #eee;cursor:pointer;font-size:12px}
.searchres .item:hover{background:var(--bg)}
.searchres .item b{color:var(--navy);display:block;font-size:13px}

/* ========== SEL BADGE ========== */
.sel-badge{position:absolute;top:56px;left:50%;transform:translateX(-50%);background:var(--navy);color:#fff;padding:6px 14px;border-radius:20px;font-size:12px;font-weight:bold;z-index:700;box-shadow:0 3px 8px rgba(0,0,0,.3);display:none;max-width:80%;text-align:center;pointer-events:auto}
.sel-badge.show{display:block}
.sel-badge .dot{display:inline-block;width:10px;height:10px;border-radius:50%;margin-right:6px;vertical-align:middle}

.modal{position:fixed;inset:0;background:rgba(27,45,94,.65);display:none;align-items:flex-end;justify-content:center;z-index:2000;padding:0}
.modal.open{display:flex}
.sheet{background:#fff;width:100%;max-width:600px;max-height:92vh;border-radius:16px 16px 0 0;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 -4px 20px rgba(0,0,0,.3)}
.sheet > header{background:var(--navy);color:#fff;padding:14px 16px;display:flex;justify-content:space-between;align-items:center}
.sheet > header h2{margin:0;font-size:16px}
.sheet > header button.close{background:transparent;border:none;color:#fff;font-size:26px;cursor:pointer;padding:0 4px;width:36px;height:36px}
.sheet .body{padding:14px 16px;overflow-y:auto;flex:1;-webkit-overflow-scrolling:touch}
.sheet .foot{padding:12px 16px;background:var(--bg);border-top:1px solid #ddd;display:flex;gap:8px}
.sheet .foot button{flex:1;padding:13px;border:none;border-radius:8px;font-weight:bold;font-size:14px;cursor:pointer;font-family:inherit}
.sheet .foot .primary{background:var(--green);color:var(--navy)}
.sheet .foot .secondary{background:#ddd;color:var(--navy)}
.sheet .foot .danger{background:var(--red);color:#fff;flex:0 0 auto;padding:13px 18px}

label{display:block;margin:12px 0 4px;font-size:12px;font-weight:600;color:var(--navy)}
input,select,textarea{width:100%;padding:11px;border:1px solid #bbb;border-radius:6px;font-size:15px;font-family:inherit;background:#fff}
input:focus,select:focus,textarea:focus{outline:2px solid var(--green);border-color:var(--green)}
.row{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}

.cat-section h3{color:var(--navy);font-size:12px;margin:14px 0 6px;border-bottom:2px solid var(--green);padding-bottom:4px;text-transform:uppercase;letter-spacing:.5px}
.cat-item{display:flex;align-items:center;gap:10px;padding:10px;background:var(--bg);border-radius:8px;margin-bottom:6px;cursor:pointer;border:2px solid transparent;transition:all .1s}
.cat-item:hover{background:#eef}
.cat-item.sel{border-color:var(--green);background:#eef7dc}
.cat-item .icon{width:46px;height:46px;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:bold;font-size:12px;flex-shrink:0;border:2px solid rgba(0,0,0,.2);box-shadow:0 1px 3px rgba(0,0,0,.2)}
.cat-item .icon.shape-circle{border-radius:50%}
.cat-item .icon.shape-square{border-radius:6px}
.cat-item .icon.shape-hex{border-radius:6px}
.cat-item .info{flex:1;min-width:0}
.cat-item .name{font-weight:bold;font-size:13px;color:var(--navy)}
.cat-item .price{font-size:11px;color:#666}
.cat-item .del{background:var(--navy);color:#fff;border:none;border-radius:4px;padding:8px 10px;font-size:12px;cursor:pointer;flex-shrink:0}

.kalk-section{margin-bottom:16px}
.kalk-section h3{background:var(--navy);color:#fff;padding:9px 11px;margin:0 0 6px;font-size:13px;border-radius:6px}
.kalk-row{display:grid;grid-template-columns:1fr 70px 80px 90px;gap:6px;padding:7px 4px;border-bottom:1px solid #eee;font-size:12px;align-items:center}
.kalk-row.head{background:var(--green);color:var(--navy);font-weight:bold;border-radius:6px;padding:7px;border:none}
.kalk-row .right{text-align:right}
.kalk-total{background:var(--navy);color:#fff;padding:12px;border-radius:6px;font-weight:bold;display:flex;justify-content:space-between;margin-top:8px;font-size:14px}

/* ========== LAYER PANEL (rechts oben) ========== */
.layerctl{position:absolute;top:10px;right:10px;background:rgba(255,255,255,.97);padding:6px;border-radius:8px;z-index:800;box-shadow:0 3px 8px rgba(0,0,0,.25);display:flex;flex-direction:column;gap:4px;min-width:100px;pointer-events:auto}
.layerctl .lrow{display:flex;gap:4px}
.layerctl .sep{height:1px;background:#ddd;margin:2px 0}
.layerctl button{background:#fff;border:1px solid #ccc;padding:7px 8px;font-size:10px;border-radius:5px;cursor:pointer;font-family:inherit;color:var(--navy);font-weight:700;flex:1}
.layerctl button.active{background:var(--navy);color:#fff;border-color:var(--navy)}
.layerctl .title{font-size:9px;color:#666;font-weight:700;text-transform:uppercase;padding:0 2px}

/* ========== LEGEND (links unten) ========== */
.legend{position:absolute;bottom:10px;left:10px;background:rgba(255,255,255,.97);padding:8px 10px;border-radius:8px;font-size:10px;z-index:800;box-shadow:0 3px 8px rgba(0,0,0,.25);line-height:1.5;max-width:240px;pointer-events:auto}
.legend .title{font-weight:bold;color:var(--navy);margin-bottom:4px;font-size:10px;text-transform:uppercase;letter-spacing:.5px}
.legend .row{display:flex;align-items:center;gap:6px;margin-bottom:2px;font-size:10px}
.legend .sw{width:14px;height:14px;border-radius:3px;flex-shrink:0}
.legend .sw.line{height:4px}
.legend hr{border:none;border-top:1px solid #ddd;margin:4px 0}
.legend button.lgBtn{background:var(--navy);color:#fff;border:none;border-radius:4px;padding:6px 10px;font-size:10px;font-weight:bold;cursor:pointer;font-family:inherit;margin-top:6px;width:100%}
.legend button.lgBtn.danger{background:var(--red);margin-top:4px}

.info{position:absolute;bottom:80px;left:50%;transform:translateX(-50%);background:var(--green);color:var(--navy);padding:9px 16px;border-radius:22px;font-size:12px;font-weight:bold;z-index:600;box-shadow:0 3px 10px rgba(0,0,0,.3);display:none;max-width:90%;text-align:center}
.info.show{display:block}
.info.err{background:var(--red);color:#fff}

/* ========== MARKERS ========== */
.mlabel{
  background:var(--pin-color,var(--navy));
  color:#fff;
  border:3px solid #fff;
  min-width:48px;
  padding:3px 5px;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  font-weight:bold;
  font-size:11px;
  margin-left:-24px!important;
  margin-top:-24px!important;
  box-shadow:0 3px 8px rgba(0,0,0,.5);
  text-align:center;
  line-height:1.1;
  text-shadow:0 1px 2px rgba(0,0,0,.4);
}
.mlabel.shape-circle{border-radius:24px}
.mlabel.shape-square{border-radius:6px}
.mlabel.shape-hex{border-radius:8px}
.mlabel .val{font-size:9px;font-weight:600;opacity:.95;margin-top:1px}
.mlabel .qty{font-size:9px;font-weight:normal;opacity:.9}
.mlabel.has-photo{border-color:#ffeb3b;box-shadow:0 3px 10px rgba(255,235,59,.7)}
.mlabel.draggable-mark{outline:2px dashed var(--orange);outline-offset:2px}

.fab{position:absolute;bottom:90px;left:50%;transform:translateX(-50%);z-index:600;background:var(--green);color:var(--navy);border:2px solid var(--navy);border-radius:26px;padding:13px 24px;font-weight:bold;font-size:15px;box-shadow:0 4px 14px rgba(0,0,0,.5);cursor:pointer;font-family:inherit}

.photos{display:flex;flex-wrap:wrap;gap:6px;margin-top:6px}
.photos .ph{position:relative;width:72px;height:72px;border-radius:6px;overflow:hidden;border:2px solid var(--navy)}
.photos .ph img{width:100%;height:100%;object-fit:cover;cursor:pointer}
.photos .ph button{position:absolute;top:2px;right:2px;background:var(--red);color:#fff;border:none;border-radius:50%;width:20px;height:20px;font-size:11px;cursor:pointer;padding:0;line-height:1}
.photo-add{width:72px;height:72px;border:2px dashed var(--navy);border-radius:6px;display:flex;align-items:center;justify-content:center;color:var(--navy);font-size:28px;cursor:pointer;background:var(--bg)}
.photo-add input{display:none}

.toggles{display:flex;gap:8px;margin-top:8px}
.toggle{flex:1;padding:12px;border:2px solid #ccc;border-radius:8px;text-align:center;cursor:pointer;font-size:12px;font-weight:bold;color:#666;background:#fff}
.toggle.on{border-color:var(--orange);background:#fff3e0;color:var(--orange)}

/* Trassen-Segment-Liste */
.seg-list{max-height:180px;overflow-y:auto;border:1px solid #ddd;border-radius:6px;margin-top:4px}
.seg-list .seg{display:flex;align-items:center;padding:8px 10px;border-bottom:1px solid #eee;font-size:12px;gap:8px;cursor:pointer}
.seg-list .seg:last-child{border-bottom:none}
.seg-list .seg:hover{background:var(--bg)}
.seg-list .seg .n{background:var(--navy);color:#fff;border-radius:4px;padding:3px 6px;font-weight:bold;font-size:11px;min-width:26px;text-align:center}
.seg-list .seg .of{padding:3px 7px;border-radius:3px;font-weight:bold;color:#fff;font-size:11px}
.seg-list .seg .len{flex:1;color:#666;font-size:11px}
.seg-list .seg .hand{font-size:10px;color:var(--orange);font-weight:bold}

.pt-list{max-height:120px;overflow-y:auto;border:1px solid #ddd;border-radius:6px;margin-top:4px}
.pt-list .pt{display:flex;align-items:center;padding:6px 10px;border-bottom:1px solid #eee;font-size:11px;gap:6px}
.pt-list .pt:last-child{border-bottom:none}
.pt-list .pt .n{background:var(--navy);color:#fff;border-radius:50%;width:20px;height:20px;display:flex;align-items:center;justify-content:center;font-weight:bold;font-size:10px;flex-shrink:0}
.pt-list .pt .coords{flex:1;color:#666;font-family:monospace;font-size:9px}
.pt-list .pt .del{background:var(--red);color:#fff;border:none;border-radius:3px;padding:4px 7px;font-size:10px;cursor:pointer}

/* Cable list im Trassen-Modal */
.cable-row{display:grid;grid-template-columns:1fr 70px 70px;gap:6px;align-items:center;padding:6px 4px;border-bottom:1px solid #eee;font-size:11px}
.cable-row .lbl{color:var(--navy);font-weight:600}
.cable-row .lbl small{display:block;color:#888;font-weight:400;font-size:9px}
.cable-row input{padding:7px;font-size:12px;text-align:right}
.cable-row .hd{font-size:9px;color:#666;font-weight:700;text-transform:uppercase;text-align:center}

/* ========== DESKTOP ========== */
@media (min-width:900px){
  header.topbar{padding:12px 20px}
  header.topbar h1{font-size:18px}
  header.topbar h1 small{font-size:12px}
  header.topbar .logo{width:38px;height:38px;font-size:22px}
  header.topbar .sum{font-size:16px;padding:10px 18px}
  .modebar{padding:10px;gap:10px}
  .modebar button{font-size:13px;padding:12px 16px;min-width:130px;max-width:220px}
  .toolbar{padding:12px;gap:10px}
  .toolbar button{font-size:14px;padding:14px 10px}
  .modal{align-items:center;padding:20px}
  .sheet{border-radius:12px;max-width:720px;max-height:85vh}
  .cat-item{padding:12px}
  .cat-item .icon{width:52px;height:52px;font-size:13px}
  .cat-item .name{font-size:14px}
  .layerctl{min-width:130px}
  .layerctl button{font-size:12px;padding:8px 12px}
  .legend{font-size:12px;padding:10px 14px;max-width:280px}
  .legend .row{font-size:11px}
  .info{font-size:14px;padding:11px 20px}
  .searchbar{max-width:500px}
  .searchbar input{font-size:14px;padding:10px}
}
@media (min-width:1200px){
  .sheet{max-width:820px}
}
</style>
</head>
<body>

<header class="topbar">
  <div class="brand">
    <div class="logo">E</div>
    <h1>TiefbauPorte<small id="hdrSub">Vor-Ort-Check · Union E</small></h1>
  </div>
  <div class="sum" id="sumTotal">0,00 €</div>
</header>

<div id="map">
  <div class="searchbar">
    <input id="srchInput" type="text" placeholder="Adresse suchen...">
    <button id="srchBtn">🔍</button>
    <button id="snapBtn" class="snap" title="Kartenausschnitt speichern">📸</button>
  </div>
  <div class="searchres" id="srchRes"></div>

  <div class="layerctl">
    <div class="title">Karte</div>
    <div class="lrow">
      <button id="lyrMap" class="active">Straße</button>
      <button id="lyrSat">Sat</button>
    </div>
    <div class="sep"></div>
    <div class="title">Sichtbar</div>
    <div class="lrow">
      <button id="lyrHW" class="active">📍 HW</button>
      <button id="lyrTR" class="active">🚧 TR</button>
    </div>
  </div>

  <div class="legend" id="legend"></div>

  <div class="sel-badge" id="selBadge"></div>
  <div class="info" id="infoBanner"></div>
</div>

<div class="modebar">
  <button id="btnModePin" class="active">📍 Objekt setzen</button>
  <button id="btnModeTrace" class="trace">🚧 Trasse zeichnen</button>
  <button id="btnModeEdit" class="edit">✋ Verschieben</button>
  <button id="btnLocate">🎯 GPS</button>
</div>

<div class="toolbar">
  <button id="btnCatalog">📋 Katalog</button>
  <button id="btnKalk">💰 Kalkulation</button>
  <button class="sec" id="btnMeta">📝 Projekt</button>
  <button class="sec" id="btnExport">📤 Export</button>
</div>

<!-- CATALOG -->
<div class="modal" id="modalCatalog"><div class="sheet">
  <header><h2>Objekt-Katalog</h2><button class="close" onclick="closeModal('modalCatalog')">✕</button></header>
  <div class="body">
    <p style="font-size:12px;color:#666;margin:4px 0 10px">Objekt antippen → in der Karte tappen zum Setzen.</p>
    <div id="catList"></div>
    <button onclick="showAddCatalog()" style="width:100%;margin-top:14px;padding:13px;background:var(--green);color:var(--navy);border:none;border-radius:8px;font-weight:bold;font-size:14px;cursor:pointer">+ Eigenes Objekt hinzufügen</button>
  </div>
</div></div>

<!-- ADD/EDIT CATALOG -->
<div class="modal" id="modalAddCat"><div class="sheet">
  <header><h2 id="addCatTitle">Neues Objekt</h2><button class="close" onclick="closeModal('modalAddCat')">✕</button></header>
  <div class="body">
    <label>Bezeichnung</label><input id="acName" placeholder="z.B. NWS Netzwerkverteiler">
    <label>Kürzel (max. 5 Zeichen)</label><input id="acIcon" maxlength="5" placeholder="NWS">
    <label>LV-Position (optional)</label><input id="acPos" placeholder="z.B. 24a.">
    <div class="row">
      <div><label>Einzelpreis (€)</label><input id="acPrice" type="number" step="0.01"></div>
      <div><label>Einheit</label><select id="acUnit"><option value="Stk">Stück</option><option value="m">Meter</option><option value="psch">pauschal</option></select></div>
    </div>
    <div class="row">
      <div><label>Farbe</label><input id="acColor" type="color" value="#1B2D5E"></div>
      <div><label>Form</label><select id="acShape"><option value="shape-circle">Kreis</option><option value="shape-square">Quadrat</option><option value="shape-hex">Abgerundet</option></select></div>
    </div>
    <label>Kategorie</label>
    <select id="acCategory">
      <option value="Ladeinfrastruktur">Ladeinfrastruktur</option>
      <option value="Verteilung">Verteilung (KVS/MWS/ZAS/NWS)</option>
      <option value="Netzanschluss">Netzanschluss (Trafo/Bestand)</option>
      <option value="Ausstattung">Ausstattung</option>
      <option value="Erdung">Erdung (Tiefenerder etc.)</option>
      <option value="Durchbruch">Durchbruch</option>
      <option value="Sonstiges">Sonstiges</option>
    </select>
    <label><input type="checkbox" id="acHasAmp" style="width:auto;margin-right:6px">Stromstärke-Feld (A) anzeigen</label>
    <label><input type="checkbox" id="acHasKw" style="width:auto;margin-right:6px">Leistungs-Feld (kW) anzeigen</label>
  </div>
  <div class="foot">
    <button class="danger" id="acDelBtn" onclick="deleteCatalogItem()">🗑</button>
    <button class="secondary" onclick="closeModal('modalAddCat')">Abbrechen</button>
    <button class="primary" onclick="saveCatalogItem()">Speichern</button>
  </div>
</div></div>

<!-- OBJECT DETAIL -->
<div class="modal" id="modalObj"><div class="sheet">
  <header><h2 id="objTitle">Objekt</h2><button class="close" onclick="closeModal('modalObj')">✕</button></header>
  <div class="body">
    <label>Typ ändern</label>
    <select id="objCatSelect"></select>
    <div class="row">
      <div><label>Anzahl</label><input id="objQty" type="number" min="1" value="1"></div>
      <div><label>Einzelpreis (€)</label><input id="objPrice" type="number" step="0.01"></div>
